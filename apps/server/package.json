{
  "name": "@alice-hns-wallet/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@alice-hns-wallet/domain": "workspace:*",
    "@alice-hns-wallet/hsd-client": "workspace:*",
    "@alice-hns-wallet/schemas": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@node-rs/argon2": "^2.0.2",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.6.16",
    "otpauth": "^9.3.6",
    "qrcode": "^1.5.4",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.5",
    "drizzle-kit": "^0.30.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
